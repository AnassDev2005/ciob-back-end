  <diagram name="Page-1" id="jdCBP1usXUEXR2NtMEva">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor User\nparticipant \&quot;Frontend (React)\&quot; as FE\nparticipant \&quot;Backend (Laravel API)\&quot; as BE\ndatabase \&quot;MySQL Database\&quot; as DB\n\nUser -&gt; FE: Click \&quot;Checkout\&quot;\nFE -&gt; BE: POST /api/checkout (Sanctum)\n\nBE -&gt; BE: Check authentication\n\nalt Not authenticated\n    BE --&gt; FE: 401 Unauthorized\n    FE --&gt; User: Redirect to Login\nelse Authenticated\n\n    BE -&gt; DB: Fetch cart items (user_id)\n    DB --&gt; BE: Cart items list\n\n    alt Cart is empty\n        BE --&gt; FE: Error (Cart empty)\n        FE --&gt; User: Show message\n    else Cart has items\n\n        BE -&gt; BE: Calculate total price\n\n        BE -&gt; DB: Create order (user_id, total_price)\n        DB --&gt; BE: Order ID created\n\n        loop For each cart item\n            BE -&gt; DB: Insert order_items (order_id, product_id, qty, price)\n        end\n\n        BE -&gt; DB: Clear cart (delete cart items)\n        DB --&gt; BE: Cart cleared\n\n        BE --&gt; FE: Success (order created)\n        FE --&gt; User: Show confirmation page\n    end\nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="H0W8qe0Tw7Ls6vF3TZ82-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="797" width="877" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
