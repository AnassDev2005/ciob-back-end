  <diagram name="Page-1" id="UmautJTT4WC4Z4rUJzAF">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor User\nparticipant \&quot;Frontend (React)\&quot; as FE\nparticipant \&quot;Backend (Laravel API)\&quot; as BE\ndatabase \&quot;MySQL Database\&quot; as DB\n\nUser -&gt; FE: Enter email &amp; password\nFE -&gt; BE: POST /api/login\n\nBE -&gt; BE: Validate request data\n\nBE -&gt; DB: Find user by email\nDB --&gt; BE: User data / null\n\nalt User not found\n    BE --&gt; FE: Error (Invalid credentials)\n    FE --&gt; User: Show error message\nelse User exists\n\n    BE -&gt; BE: Verify password (bcrypt check)\n\n    alt Wrong password\n        BE --&gt; FE: Error (Invalid credentials)\n        FE --&gt; User: Show error message\n    else Password correct\n\n        BE -&gt; BE: Generate Auth Token (JWT / Sanctum)\n\n        BE -&gt; BE: Check user role (admin / client)\n\n        alt Role = Admin\n            BE --&gt; FE: Success (token + role=admin)\n            FE -&gt; FE: Store token\n            FE --&gt; User: Redirect to Admin Dashboard\n\n        else Role = Client\n            BE --&gt; FE: Success (token + role=client)\n            FE -&gt; FE: Store token\n            FE --&gt; User: Redirect to Home Page\n        end\n\n    end\nend\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="CdwFs1fQeA08M1goX-7G-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
