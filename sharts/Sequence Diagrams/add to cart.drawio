  <diagram name="Page-1" id="QWQL98PuGd0Fh343srd-">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor User\nparticipant \&quot;Frontend (React)\&quot; as FE\nparticipant \&quot;Backend (Laravel API)\&quot; as BE\ndatabase \&quot;MySQL Database\&quot; as DB\n\nUser -&gt; FE: Click \&quot;Add to Cart\&quot;\nFE -&gt; BE: POST /api/cart (product_id, quantity)\n\nBE -&gt; BE: Check authentication (Sanctum)\n\nalt User not authenticated\n    BE --&gt; FE: Error (401 Unauthorized)\n    FE --&gt; User: Redirect to Login page\nelse User authenticated\n\n    BE -&gt; DB: Check product exists\n\n    DB --&gt; BE: Product data / null\n\n    alt Product not found\n        BE --&gt; FE: Error (Product not found)\n        FE --&gt; User: Show error message\n    else Product exists\n\n        BE -&gt; DB: Check if product already in cart\n\n        DB --&gt; BE: Cart item / null\n\n        alt Item already in cart\n            BE -&gt; DB: Update quantity\n        else New item\n            BE -&gt; DB: Insert into cart (user_id, product_id, qty)\n        end\n\n        DB --&gt; BE: Cart updated\n\n        BE --&gt; FE: Success (updated cart)\n        FE --&gt; User: Show cart updated UI\n    end\nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="x7Z7xl7Q9aX5bZHwaLGH-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="770" width="871" x="130" y="20" as="geometry" />
          </mxCell>
        </UserObject>
